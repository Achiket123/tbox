#!/bin/sh
TBOX_HOME="${TBOX_HOME:-$HOME/.tbox}"
TARGET="${1:-}"
[ -z "$TARGET" ] && echo "Usage: tbox stop <name|id>" && exit 1
CDIR="$TBOX_HOME/containers/$TARGET"
[ -d "$CDIR" ] || { echo "Container not found: $TARGET"; exit 1; }

# Kill main process
if [ -f "$CDIR/pid" ]; then
    PID=$(cat "$CDIR/pid")
    if [ -n "$PID" ]; then
        kill "$PID" 2>/dev/null || true
        # Kill children too
        pkill -P "$PID" 2>/dev/null || true
    fi
fi

# Kill socat port forwards
while read pid; do
    kill "$pid" 2>/dev/null || true
done < "$CDIR/socat_pids" 2>/dev/null

echo "stopped" > "$CDIR/status"
echo "Stopped $TARGET"
